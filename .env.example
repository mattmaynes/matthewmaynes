# Public site configuration. No secrets belong in this file or in git.
# Copy to .env.local for local development (.env* is git-ignored except this file).

# Canonical site origin, used for absolute URLs / metadata.
SITE_URL=https://matthewmaynes.com

# Node environment: development | production | test
NODE_ENV=development

# Contact form (spec 0008). Server-only - NEVER prefixed NEXT_PUBLIC_, so the
# destination address never reaches the browser or this public repo. Leave blank
# here; set real values in the git-ignored .env.local (local) or the host's
# git-ignored deploy/docker/.env.site (production, read via compose env_file).
#   RESEND_API_KEY   - Resend API key (secret).
#   CONTACT_TO_EMAIL - where messages are delivered (the private inbox).
#   CONTACT_FROM_EMAIL - verified-domain sender; defaults to contact@matthewmaynes.com.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
