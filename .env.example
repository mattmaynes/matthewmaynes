# Public site configuration. No secrets belong in this file or in git.
# Copy to .env.local for local development (.env* is git-ignored except this file).

# Canonical site origin, used for absolute URLs / metadata.
SITE_URL=https://matthewmaynes.com

# Node environment: development | production | test
NODE_ENV=development

# Contact form (spec 0008). Server-only - NEVER prefixed NEXT_PUBLIC_, so the
# destination address never reaches the browser or this public repo. Leave blank
# here; set real values in the git-ignored .env.local (local) or the host's
# git-ignored deploy/docker/.env.site (production, read via compose env_file).
#   RESEND_API_KEY   - Resend API key (secret).
#   CONTACT_TO_EMAIL - where messages are delivered (the private inbox).
#   CONTACT_FROM_EMAIL - verified-domain sender; defaults to contact@matthewmaynes.com.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=

# PostHog analytics / session replay / error tracking (spec 0014). Unlike the
# contact secrets above, these are NEXT_PUBLIC_ and are INLINED at build time
# (not read at runtime). The key is PostHog's *publishable* project key (the
# phc_ client token) - it ships in the browser bundle by design, so it is not a
# secret and src/lib/analytics.ts carries a committed default. Set these only to
# target a different PostHog project; a build without them uses the default.
#   NEXT_PUBLIC_POSTHOG_KEY  - publishable phc_ project key (US Cloud).
#   NEXT_PUBLIC_POSTHOG_HOST - client ingest host; defaults to the /ingest proxy.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=/ingest
