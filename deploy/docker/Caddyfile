# Caddy routes by hostname and provisions/renews Let's Encrypt certs automatically
# (needs ports 80/443 reachable and DNS pointing at this server first). HTTP is
# redirected to HTTPS automatically. No ACME email is set on purpose: a personal
# address must never live in a tracked file (see docs/overview/project.md privacy).

# Apex: serve the site, proxying to the standalone Next server on the edge network.
matthewmaynes.com {
	encode zstd gzip
	# HSTS belongs at the TLS terminator. The app sets the other security headers
	# (X-Frame-Options, X-Content-Type-Options, ...) in next.config.ts.
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"
	# Zero-downtime deploys (spec 0019): a static `reverse_proxy site:3000` resolves
	# the name once and caches the IP, so it would keep hitting the OLD container
	# after a docker-rollout swap. Dynamic A upstreams re-resolve the `site` alias
	# against Docker's embedded DNS (127.0.0.11) every second, so Caddy load-balances
	# across whatever instances are live and follows the swap. During a rollout both
	# instances resolve; when the old one is removed, the next refresh drops it. Two
	# mechanisms close the <=1s window where Caddy's cached set still lists the gone
	# IP: `fail_duration` (passive health) shelves an upstream that fails to CONNECT,
	# and `lb_try_duration`/`lb_retries` retry the request onto a live instance. A
	# warming new instance that is not yet listening likewise fails to dial and is
	# shelved/retried. `fail_duration` counts only transport/connect failures (no
	# `unhealthy_status`), so a genuine app 5xx never benches the sole steady-state
	# upstream - and when the upstream is truly unreachable there is nothing to fail
	# over to anyway, so shelving it does no harm (review 0019). Tuned (lb_retries 3 +
	# fail_duration) to close the swap window; verified by polling through a real deploy.
	reverse_proxy {
		dynamic a {
			name site
			port 3000
			refresh 1s
			resolvers 127.0.0.11
			versions ipv4
			dial_timeout 3s
		}
		lb_try_duration 5s
		lb_retries 3
		fail_duration 2s
	}
}

# www -> apex. Caddy still issues a cert for www so the redirect is served over HTTPS.
www.matthewmaynes.com {
	redir https://matthewmaynes.com{uri} permanent
}

# Cohosted site: rogueoak.com. This proxy is the single owner of the edge TLS
# terminator, so every domain served from this host is routed here (the rogueoak
# repo ships only its own site stack, joined to the shared `edge` network as
# `rogueoak`). See docs/overview for the cohosting arrangement.
rogueoak.com {
	encode zstd gzip
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"
	# Same dynamic-upstream routing as the apex (spec 0019): re-resolve the
	# `rogueoak` service alias against Docker DNS so Caddy follows rogueoak's own
	# zero-downtime rollout (its deploy mirrors this one). Works unchanged while
	# rogueoak is still a single container - the alias resolves either way.
	reverse_proxy {
		dynamic a {
			name rogueoak
			port 3000
			refresh 1s
			resolvers 127.0.0.11
			versions ipv4
			dial_timeout 3s
		}
		lb_try_duration 5s
		lb_retries 3
		fail_duration 2s
	}
}

# www -> apex. Caddy still issues a cert for www so the redirect is served over HTTPS.
www.rogueoak.com {
	redir https://rogueoak.com{uri} permanent
}
